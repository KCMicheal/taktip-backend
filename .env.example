# Database & Redis
DATABASE_URL=postgresql://taktip:devpassword@localhost:5432/taktip_dev
REDIS_URL=redis://localhost:6379

# API Versioning
API_VERSION=v1

# CORS - Comma-separated list of allowed origins
# Development: localhost ports for FE dev server
# Staging/Production: Your deployed URLs
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT Configuration
JWT_PRIVATE_KEY_PATH=./keys/ed25519_private.pem
JWT_PUBLIC_KEY_PATH=./keys/ed25519_public.pem
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
REFRESH_TOKEN_EXPIRY_DAYS=7

# Payment (Paystack)
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxx

# Email (MailJet)
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_API_SECRET=your_mailjet_api_secret
MAILJET_SENDER_EMAIL=noreply@taktip.io
MAILJET_SENDER_NAME=TakTip

# OTP Configuration
OTP_EXPIRY_MINUTES=15

# Server
APP_PORT=3001